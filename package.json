{
  "name": "nova-trust-digital-finance",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "contracts"
  ],
  "scripts": {
    "start": "npm run start --workspace @nova/dashboard --",
    "start:dashboard": "npm run start --workspace @nova/dashboard --",
    "start:api": "npm run start --workspace @nova/api --",
    "start:indexer": "npm run start --workspace @nova/indexer --",
    "dev:dashboard": "npm run dev --workspace @nova/dashboard",
    "dev:api": "npm run dev --workspace @nova/api",
    "dev:indexer": "npm run dev --workspace @nova/indexer",
    "test:contracts": "npm run test --workspace @nova/contracts",
    "test:custody": "npm run test:custody --workspace @nova/api",
    "release:check": "npm run build",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.16",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "$esbuild",
    "postcss": "$postcss"
  }
}
