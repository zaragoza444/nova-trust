# Z Dashboard LXC 5825 — omnl-office24-portal
#   cp deploy/proxmox/z-lxc-dashboard.env.example /opt/nova-trust/deploy/.env.z-production

export NODE_ENV=production
export Z_DASHBOARD_PORT=3100
export PORT=3100

# SSR server-side fetches hit hub API directly
export Z_API_URL="http://192.168.11.126:4100"

# Browser uses same-origin /api via portal nginx (empty = relative URLs)
export NEXT_PUBLIC_Z_API_URL=""
export Z_DASHBOARD_ROLE="AUDITOR"
export Z_CORS_ORIGIN="http://192.168.11.121,http://192.168.11.122,http://192.168.11.123,http://192.168.11.124,http://192.168.11.126,http://192.168.11.127,http://192.168.11.186,http://192.168.11.187,http://192.168.11.188"
