# Proxmox GitHub Actions secrets for Z Ecosystem LXC deploy (5820–5828)
# Copy and fill in management IPs, then run:
#   source deploy/proxmox/github-secrets.env
#   bash scripts/setup-proxmox-github-secrets.sh --apply
#
# Do NOT commit real keys or passwords to git.

# --- Required: Proxmox management IPs (NOT the LXC 192.168.11.x addresses) ---
export PROXMOX_R630_04_HOST="192.168.11.???"   # r630-04 — VMIDs 5820–5824
export PROXMOX_R630_03_HOST="192.168.11.???"   # r630-03 — VMIDs 5825–5828

# Optional fallback if both nodes reachable via one IP / jump host
# export PROXMOX_SSH_HOST="192.168.11.???"

export PROXMOX_SSH_USER="root"

# --- Auth: set ONE of these locally before --apply (never commit values) ---
# export PROXMOX_SSH_PRIVATE_KEY="$(cat ~/.ssh/id_ed25519)"
# export PROXMOX_SSH_PASSWORD="your-root-password"

# GitHub repo for gh secret set
export GITHUB_REPOSITORY="zaragoza444/nova-trust"
