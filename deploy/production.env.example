# Nova Trust production runtime — copy to deploy/.env.production on the VPS.
#   cp deploy/production.env.example deploy/.env.production
#   source deploy/.env.production

export NODE_ENV=production
export PORT=4000
export NOVA_API_HOST="0.0.0.0"
export NOVA_CORS_ORIGIN="http://127.0.0.1:3000"

# Dashboard → API
export NOVA_API_URL="http://127.0.0.1:4000"
export NOVA_DASHBOARD_ROLE="AUDITOR"

# Z Blockchain (local Ganache on VPS / dev)
export ZBC_RPC_URL="http://127.0.0.1:8546"
export ZBC_EXPECTED_CHAIN_ID="44002"
export ZBC_BOOTSTRAP_MANIFEST_PATH="contracts/deployments/z-blockchain-production-liquidity.json"

# Multi-network public RPCs (TRON basement + Ethereum + BNB)
export TRON_NETWORK_ID="mainnet"
export TRON_RPC_URL="https://api.trongrid.io"
export ETH_RPC_URL="https://ethereum.publicnode.com"
export BSC_RPC_URL="https://bsc-dataseed.binance.org"
export MULTI_NETWORK_BASEMENT_CHAIN_ID="728126428"
export MULTI_NETWORK_ETH_CHAIN_ID="1"
export MULTI_NETWORK_BSC_CHAIN_ID="56"

# Optional custody keys — leave unset for read-only go-live
# export DFNS_AUTH_TOKEN=
# export COBO_API_SECRET=
