# Copy to a private location, fill values, then source before NRW World bootstrap.
# Example:
#   cp contracts/nrw-world.env.example /tmp/nrw-world-production.env
#   editor /tmp/nrw-world-production.env
#   source /tmp/nrw-world-production.env
#   npm run setup:nrw-world:preflight --workspace @nova/contracts
#   npm run setup:nrw-world --workspace @nova/contracts

export NRW_RPC_URL="<nrw-world-rpc-url>"
export NRW_DEPLOYER_PRIVATE_KEY="<funded-deployer-private-key>"
export NRW_EXPECTED_CHAIN_ID="33001"
export NRW_NETWORK_NAME="NRW World"

export NRW_M1FIAT_SUPPLY="1000000"
export NRW_M1FIAT_LIQUIDITY="100000"
export NRW_WNRW_LIQUIDITY="100"

export NRW_ACX_SUPPLY="500000"
export NRW_ACX_LIQUIDITY="50000"
export NRW_WNRW_ACX_LIQUIDITY="50"

export NRW_SHIVA_SUPPLY="500000"
export NRW_SHIVA_LIQUIDITY="50000"
export NRW_WNRW_SHIVA_LIQUIDITY="50"

# export NRW_BOOTSTRAP_MANIFEST_PATH="./contracts/deployments/nrw-world-liquidity.json"
