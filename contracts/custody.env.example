# Copy to a private location, fill values, then source before API start or custody tests.
# Example:
#   cp contracts/custody.env.example /tmp/custody.env
#   editor /tmp/custody.env
#   source /tmp/custody.env
#   npm run test:custody --workspace @nova/api

# === DFNS ===
export DFNS_API_BASE_URL="https://api.dfns.io"
export DFNS_ORG_ID="<dfns-org-id>"
export DFNS_AUTH_TOKEN="<dfns-service-account-jwt>"
export DFNS_CRED_ID="<dfns-credential-id>"
# PEM private key; use literal newlines or \n escapes in a single line.
export DFNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# === COBO ===
# Use "dev" or "prod" to match the environment where the key is registered on Cobo Portal.
export COBO_ENV="prod"
export COBO_API_KEY="<cobo-api-key-hex>"
export COBO_API_SECRET="<cobo-api-secret-hex>"

# Register these URLs on Cobo Portal (prepend your public API base URL):
#   ${PUBLIC_API_BASE_URL}/api/custody/cobo/webhook
#   ${PUBLIC_API_BASE_URL}/api/custody/cobo/callback
# export COBO_CALLBACK_URL="https://your-api.example.com/api/custody/cobo/callback"

# Optional Dfns treasury wallet override (defaults to first listed wallet)
# export DFNS_TREASURY_WALLET_ID="<dfns-wallet-id>"

# Dev-only: skip Cobo webhook signature verification
# export COBO_WEBHOOK_SKIP_VERIFY="true"
