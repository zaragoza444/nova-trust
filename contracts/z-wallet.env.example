# Z Wallet production setup on Z Blockchain (44002)
# Copy to deploy/.env.production or source before setup:
#   cp contracts/z-wallet.env.example deploy/.env.z-wallet
#   source deploy/.env.z-wallet

export ZBC_RPC_URL="http://127.0.0.1:8546"
export ZBC_EXPECTED_CHAIN_ID="44002"
export ZBC_BOOTSTRAP_MANIFEST_PATH="contracts/deployments/z-blockchain-production-liquidity.json"

# Production Z Wallet address (public — safe to share)
export Z_WALLET_ADDRESS="0xc2D6E6981D1A415967A683D615cf97bA9bC26F0f"

# Admin key used to register the wallet on IdentityRegistry (never commit real keys)
export ZBC_DEPLOYER_PRIVATE_KEY="0xYOUR_ADMIN_OR_DEPLOYER_PRIVATE_KEY"

# Z Wallet signing key for production transfers (never commit — store in HSM/KMS on VPS)
# export Z_WALLET_PRIVATE_KEY="0xYOUR_Z_WALLET_PRIVATE_KEY"

# Optional role overrides when registering the wallet
# export Z_WALLET_PARTICIPANT_ROLE="z-wallet-production"
# export Z_WALLET_KYC_ATTESTATION="Z_WALLET_PRODUCTION_KYC"
