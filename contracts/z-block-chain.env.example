# Copy to a private location, fill values, then source before Z Block Chain bootstrap.
# Example:
#   cp contracts/z-block-chain.env.example /tmp/z-block-chain-production.env
#   editor /tmp/z-block-chain-production.env
#   source /tmp/z-block-chain-production.env
#   npm run setup:z-block-chain:preflight --workspace @nova/contracts
#   npm run setup:z-block-chain --workspace @nova/contracts

export ZBC_RPC_URL="<z-block-chain-rpc-url>"
export ZBC_DEPLOYER_PRIVATE_KEY="<funded-deployer-private-key>"
export ZBC_EXPECTED_CHAIN_ID="44002"
export ZBC_NETWORK_NAME="Z Block Chain"

export ZBC_M1FIAT_SUPPLY="1000000"
export ZBC_M1FIAT_LIQUIDITY="100000"
export ZBC_WZ_LIQUIDITY="100"

export ZBC_ACX_SUPPLY="500000"
export ZBC_ACX_LIQUIDITY="50000"
export ZBC_WZ_ACX_LIQUIDITY="50"

export ZBC_SHIVA_SUPPLY="500000"
export ZBC_SHIVA_LIQUIDITY="50000"
export ZBC_WZ_SHIVA_LIQUIDITY="50"

# export ZBC_BOOTSTRAP_MANIFEST_PATH="./contracts/deployments/z-block-chain-liquidity.json"
