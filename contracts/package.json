{
  "name": "@nova/contracts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test && node --test --experimental-strip-types ./test/NovaContractSuite.spec.ts",
    "deploy": "node --experimental-strip-types ./scripts/deploy.ts",
    "setup:production": "node --experimental-strip-types ./scripts/setup-production-liquidity.ts",
    "setup:local": "bash ./scripts/run-local-bootstrap.sh",
    "setup:production:preflight": "node --experimental-strip-types ./scripts/preflight-production.ts",
    "setup:z-block-chain": "node --experimental-strip-types ./scripts/setup-z-block-chain-liquidity.ts",
    "setup:z-block-chain:local": "bash ./scripts/run-local-z-block-chain-bootstrap.sh",
    "setup:z-block-chain:preflight": "node --experimental-strip-types ./scripts/preflight-z-block-chain.ts",
    "setup:nrw-world": "node --experimental-strip-types ./scripts/setup-nrw-world-liquidity.ts",
    "setup:nrw-world:local": "bash ./scripts/run-local-nrw-world-bootstrap.sh",
    "setup:nrw-world:preflight": "node --experimental-strip-types ./scripts/preflight-nrw-world.ts",
    "setup:multi-network:preflight": "node --experimental-strip-types ./scripts/preflight-multi-network.ts",
    "setup:clone-tokens:z-block-chain": "node --experimental-strip-types ./scripts/setup-clone-tokens-z-block-chain.ts",
    "setup:clone-tokens-100b:z-block-chain": "ZBC_CLONE_CATALOG_PATH=config/tokens/clone-tokens-100b.v1.json node --experimental-strip-types ./scripts/setup-clone-tokens-z-block-chain.ts",
    "setup:clone-btc-1m:z-block-chain": "ZBC_CLONE_CATALOG_PATH=config/tokens/clone-tokens-btc-1m.v1.json node --experimental-strip-types ./scripts/setup-clone-tokens-z-block-chain.ts",
    "setup:oracle:z-block-chain": "node --experimental-strip-types ./scripts/setup-z-block-chain-oracle.ts",
    "setup:clone-tokens:z-block-chain:local": "bash ./scripts/run-local-clone-tokens-bootstrap.sh"
  },
  "devDependencies": {
    "hardhat": "^3.9.1"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
