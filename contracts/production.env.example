# Copy this file to a private, untracked location, fill real values, then source it
# from a terminal before running the production bootstrap.
#
# Example:
#   cp contracts/production.env.example /tmp/nova-production.env
#   editor /tmp/nova-production.env
#   source /tmp/nova-production.env
#   npm run setup:production --workspace @nova/contracts
#
# Never paste these exports into CSS, TypeScript, Solidity, or any tracked source file.

export NOVA_RPC_URL="<nova-one-rpc-url>"
export NOVA_DEPLOYER_PRIVATE_KEY="<funded-deployer-private-key>"

# M1FIAT — swappable, tradable, transferable; loadable from Z Bank online
export NOVA_M1FIAT_SUPPLY="1000000"
export NOVA_M1FIAT_LIQUIDITY="100000"
export NOVA_WNOVA_LIQUIDITY="100"

# ACX — Chain 138 exchange token
export NOVA_ACX_SUPPLY="500000"
export NOVA_ACX_LIQUIDITY="50000"
export NOVA_WNOVA_ACX_LIQUIDITY="50"

# SHIVA — Chain 138 utility/trading token
export NOVA_SHIVA_SUPPLY="500000"
export NOVA_SHIVA_LIQUIDITY="50000"
export NOVA_WNOVA_SHIVA_LIQUIDITY="50"

# Optional. Leave owner/compliance/issuer unset for one-command bootstrap,
# or set them to the same deployer wallet address.
export NOVA_EXPECTED_CHAIN_ID="22016"
# export NOVA_INITIAL_OWNER="<deployer-wallet-address>"
# export NOVA_COMPLIANCE_ADMIN="<deployer-wallet-address>"
# export NOVA_TREASURY_OPERATOR="<treasury-operator-address>"
# export NOVA_ASSET_ISSUER="<deployer-wallet-address>"
# export NOVA_AUDITOR="<auditor-address>"
# export NOVA_PRODUCTION_BOOTSTRAP_MANIFEST_PATH="./contracts/deployments/nova-one-liquidity.json"
