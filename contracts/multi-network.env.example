# Multi-network production RPC endpoints (TRON basement + Ethereum + BNB Smart Chain)
# Copy to a private location on the VPS, fill optional keys, then source before API start.
#
#   cp contracts/multi-network.env.example /home/ubuntu/nova-trust/.env.multi-network
#   source /home/ubuntu/nova-trust/.env.multi-network
#   npm run test:multi-network --workspace @nova/api

# TRON basement foundation (mainnet)
export TRON_NETWORK_ID="mainnet"
export TRON_RPC_URL="https://api.trongrid.io"
# Optional TronGrid Pro key for higher rate limits
# export TRON_API_KEY="<trongrid-api-key>"

# Ethereum mainnet (public RPC — replace with Infura/Alchemy for production SLA)
export ETH_RPC_URL="https://ethereum.publicnode.com"

# BNB Smart Chain mainnet
export BSC_RPC_URL="https://bsc-dataseed.binance.org"

# Z Blockchain permissioned settlement (VPS local Ganache on 44002)
export ZBC_RPC_URL="http://127.0.0.1:8546"

# Cross-chain registry reference IDs
export MULTI_NETWORK_BASEMENT_CHAIN_ID="728126428"
export MULTI_NETWORK_ETH_CHAIN_ID="1"
export MULTI_NETWORK_BSC_CHAIN_ID="56"
