# Multi-network RPC endpoints (TRON basement + Ethereum + BNB Smart Chain)
# Copy to a private env file and source before custody or bridge operations.

# TRON basement foundation (mainnet)
TRON_NETWORK_ID=mainnet
TRON_RPC_URL=https://api.trongrid.io
TRON_API_KEY=

# Ethereum mainnet
ETH_RPC_URL=https://mainnet.infura.io/v3/your-project-id

# BNB Smart Chain
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Cross-chain registry reference IDs
MULTI_NETWORK_BASEMENT_CHAIN_ID=728126428
MULTI_NETWORK_ETH_CHAIN_ID=1
MULTI_NETWORK_BSC_CHAIN_ID=56
