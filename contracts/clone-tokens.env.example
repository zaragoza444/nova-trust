# Clone token mint defaults for Z Blockchain (44002)
# Source after z-block-chain bootstrap manifest exists.

export ZBC_RPC_URL="http://127.0.0.1:8546"
export ZBC_DEPLOYER_PRIVATE_KEY="<funded-deployer-private-key>"
export ZBC_EXPECTED_CHAIN_ID="44002"
export ZBC_BOOTSTRAP_MANIFEST_PATH="./contracts/deployments/z-block-chain-liquidity.json"

# Default per-token amounts (18 decimals)
export ZBC_CLONE_DEFAULT_SUPPLY="1000000"
export ZBC_CLONE_DEFAULT_LIQUIDITY="100000"
export ZBC_CLONE_DEFAULT_WRAPPED_LIQUIDITY="100"

# Optional per-token overrides:
# export ZBC_USDT_SUPPLY="2000000"
# export ZBC_USDT_LIQUIDITY="200000"
# export ZBC_USDT_WZ_LIQUIDITY="200"

# Force re-mint even if symbol already exists in manifest (not recommended)
# export ZBC_CLONE_FORCE_REMINT="true"
